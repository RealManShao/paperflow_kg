# Copy this file to .env and fill in your own values.

# ---------- Neo4j (Bolt) - used by src/build_kg.py ----------
# For Neo4j Aura, it often looks like: neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=neo4j://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=
NEO4J_PASSWORD=

# ---------- Neo4j (HTTP Query API) - used by src/llm_qa.py, src/graph_retrieval.py, src/reasoning.py ----------
# Neo4j Aura Query API v2 example:
# https://<id>.databases.neo4j.io/db/<database>/query/v2
NEO4J_QUERY_API_URL=

# Set to false if your environment has SSL interception and requests fails.
NEO4J_VERIFY_SSL=true

# ---------- LLM (OpenAI-compatible) ----------
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=

# Aliases (optional):
# If you already use these env vars elsewhere, the code will pick them up.
DEEPSEEK_API_BASE=
DASHSCOPE_API_KEY=
